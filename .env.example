# Base URL for the rfc-api backend.
#
# - Local dev (per docs/integration/rfc-api-reference.md#local-development):
#     RFC_API_URL=http://localhost:8080
# - Container / k8s deployments: set to the cluster-internal service URL.
#
# Vite only exposes vars prefixed with VITE_ to the client by default.
# `src/portal/api/config.ts` reads the unprefixed form first so SSR /
# Node entry points pick it up via process.env, then falls back to
# VITE_RFC_API_URL for client-side.
RFC_API_URL=http://localhost:8080

# GitHub Personal Access Token (classic) with the `read:packages` scope.
# Required to install `@donaldgifford/design-system` from GitHub Packages
# (see README §Install and `bunfig.toml` for the scope mapping).
#
# In CI the workflow passes `secrets.GITHUB_TOKEN` as `NPM_TOKEN` — set
# this only for local dev. Copy this file to `.env.local` (gitignored)
# and replace the placeholder. `mise.toml [env]` auto-loads `.env.local`.
NPM_TOKEN=ghp_replace-me

# `API_MODE=msw` boots the dev server with MSW-backed handlers serving
# fixtures from `tests/examples/docs/` instead of hitting `RFC_API_URL`.
# Lets you iterate on the portal UI with no rfc-api / Postgres / GitHub
# webhook running. See IMPL-0002 + PLAN-0001.
#
# `just dev-msw` (or `bun run dev:msw`) sets both flags for you — you
# don't need to put them in `.env.local` unless you want every `bun run
# dev` invocation to use MSW. The split exists because Vite only
# inlines `VITE_`-prefixed vars for the client bundle; the unprefixed
# form is read by the SSR-side boot module.
# API_MODE=msw
# VITE_API_MODE=msw
