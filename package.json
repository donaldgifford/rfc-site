{
  "name": "rfc-site",
  "version": "0.0.0",
  "description": "SSR web frontend for the rfc-api Markdown portal. See docs/design/0001-portal-architecture-and-ds-candidates-promotion-model.md.",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typegen": "react-router typegen",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@react-router/dev": "^7.14.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^8.0.10",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@react-router/fs-routes": "^7.14.2",
    "@react-router/node": "^7.14.2",
    "@react-router/serve": "^7.14.2",
    "react": "^19",
    "react-dom": "^19",
    "react-router": "^7.14.2"
  }
}
